.modal-close-btn,
.cart-close-btn,
.mobile-nav-close,
.qty-btn,
.qty-stepper-btn,
.search-clear-btn,
.shop-dropdown-btn,
.icon-btn,
.hamburger-btn {
  min-width: var(--mobile-touch-target);
  min-height: var(--mobile-touch-target);
}

