/* Mobile Layout Review fixes from audit report.
   This is the final responsive hardening layer: keep mobile browser chrome,
   very-small phones, touch targets, modals, and tablet widths predictable. */

:root {
  --mobile-header-height: 72px;
  --mobile-touch-target: 44px;
}

.mobile-nav,
.cart-drawer {
  height: 100vh;
  height: 100dvh;
  max-height: 100dvh;
}

.mobile-nav-body,
.cart-drawer .cart-items {
  -webkit-overflow-scrolling: touch;
}

.modal-content,
.image-zoom-shell {
  max-height: calc(100vh - 24px);
  max-height: calc(100dvh - 24px);
}

.modal-body,
.quick-view-body,
.image-zoom-stage {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.hero-arrow,
.hero-dot,
.filter-chip,
.category-chip,
.quick-view-btn,
.product-thumb,
.image-zoom-btn,
.image-zoom-close,
.image-zoom-nav,
